# Dashboard auth (whitelist)
ALLOWED_EMAILS=alice@beam.place,bob@beam.place

# Google SSO (OAuth app in Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Backend API — must be the gateway (API) origin, not the dashboard URL
NEXT_PUBLIC_API_URL=http://localhost:3000

# Optional: admin users API path (default /v1/admin/users)
# NEXT_PUBLIC_ADMIN_USERS_PATH=/v1/admin/users

# Optional: user list pagination query style — offset (default: limit+offset) or page (page+pageSize)
# NEXT_PUBLIC_ADMIN_USERS_PAGINATION=offset

# Optional: send search box to list API as this query key (server-side search)
# NEXT_PUBLIC_ADMIN_USERS_SEARCH_PARAM=q

# Optional: same numeric meaning as API `REPORT_THRESHOLD` (default 5) — shown on the Report modal until an API response supplies the value
# NEXT_PUBLIC_REPORT_THRESHOLD=5

# NextAuth
NEXTAUTH_SECRET=generate-a-random-secret
NEXTAUTH_URL=http://localhost:3020
