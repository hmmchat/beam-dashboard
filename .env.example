# Dashboard auth (whitelist)
ALLOWED_EMAILS=alice@beam.place,bob@beam.place

# Google SSO (OAuth app in Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Backend API — must be the gateway (API) origin, not the dashboard URL
NEXT_PUBLIC_API_URL=http://localhost:3000

# Optional: admin users API path (default /v1/admin/users)
# NEXT_PUBLIC_ADMIN_USERS_PATH=/v1/admin/users

# NextAuth
NEXTAUTH_SECRET=generate-a-random-secret
NEXTAUTH_URL=http://localhost:3020
